   3.9832422215059023`*^9}},ExpressionUUID->"fd4e4a65-74df-41bd-86c1-\
5b87760f7676"],

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{
   RowBox[{"k3", "*", 
    RowBox[{"m1", "^", "2"}], "*", 
    RowBox[{"H", "[", 
     RowBox[{
      RowBox[{"-", "a"}], ",", 
      RowBox[{"-", "b"}]}], "]"}], "*", 
    RowBox[{"H", "[", 
     RowBox[{"a", ",", "b"}], "]"}]}], "-", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"k3", "*", 
      RowBox[{"m1", "^", "2"}], "*", 
      RowBox[{"H", "[", 
       RowBox[{"a", ",", 
        RowBox[{"-", "a"}]}], "]"}], "*", 
      RowBox[{"H", "[", 
       RowBox[{"b", ",", 
        RowBox[{"-", "b"}]}], "]"}]}], ")"}], "/", "4"}], "+", 
   RowBox[{"k3", "*", "m1", "*", 
    RowBox[{"H", "[", 
     RowBox[{"b", ",", 
      RowBox[{"-", "b"}]}], "]"}], "*", 
    RowBox[{
     RowBox[{"dd", "[", 
      RowBox[{"-", "a"}], "]"}], "[", 
     RowBox[{"V", "[", "a", "]"}], "]"}]}], "+", 
   RowBox[{"k1", "*", 
    RowBox[{"H", "[", 
     RowBox[{"a", ",", "b"}], "]"}], "*", 
    RowBox[{
     RowBox[{"dd", "[", 
      RowBox[{"-", "b"}], "]"}], "[", 
     RowBox[{
      RowBox[{"dd", "[", 
       RowBox[{"-", "a"}], "]"}], "[", 
      RowBox[{"H", "[", 
       RowBox[{"c", ",", 
        RowBox[{"-", "c"}]}], "]"}], "]"}], "]"}]}], "+", 
   RowBox[{"2", "*", "k3", "*", 
    RowBox[{"V", "[", "a", "]"}], "*", 
    RowBox[{
     RowBox[{"dd", "[", 
      RowBox[{"-", "b"}], "]"}], "[", 
     RowBox[{
      RowBox[{"dd", "[", 
       RowBox[{"-", "a"}], "]"}], "[", 
      RowBox[{"V", "[", "b", "]"}], "]"}], "]"}]}], "-", 
   RowBox[{"2", "*", "k3", "*", 
    RowBox[{"V", "[", "a", "]"}], "*", 
    RowBox[{
     RowBox[{"dd", "[", 
      RowBox[{"-", "b"}], "]"}], "[", 
     RowBox[{
      RowBox[{"dd", "[", "b", "]"}], "[", 
      RowBox[{"V", "[", 
       RowBox[{"-", "a"}], "]"}], "]"}], "]"}]}], "-", 
   RowBox[{"4", "*", "k3", "*", "m1", "*", 
    RowBox[{"H", "[", 
     RowBox[{
      RowBox[{"-", "a"}], ",", 
      RowBox[{"-", "b"}]}], "]"}], "*", 
    RowBox[{
     RowBox[{"dd", "[", "b", "]"}], "[", 
     RowBox[{"V", "[", "a", "]"}], "]"}]}], "+", 
   RowBox[{"k2", "*", 
    RowBox[{"H", "[", 
     RowBox[{"a", ",", "b"}], "]"}], "*", 
    RowBox[{
     RowBox[{"dd", "[", 
      RowBox[{"-", "c"}], "]"}], "[", 
     RowBox[{
      RowBox[{"dd", "[", 
       RowBox[{"-", "b"}], "]"}], "[", 
      RowBox[{"H", "[", 
       RowBox[{
        RowBox[{"-", "a"}], ",", "c"}], "]"}], "]"}], "]"}]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "k1"}], "-", 
      RowBox[{"k2", "/", "2"}], "+", "k3"}], ")"}], "*", 
    RowBox[{"H", "[", 
     RowBox[{"a", ",", 
      RowBox[{"-", "a"}]}], "]"}], "*", 
    RowBox[{
     RowBox[{"dd", "[", 
      RowBox[{"-", "c"}], "]"}], "[", 
     RowBox[{
      RowBox[{"dd", "[", 
       RowBox[{"-", "b"}], "]"}], "[", 
      RowBox[{"H", "[", 
       RowBox[{"b", ",", "c"}], "]"}], "]"}], "]"}]}], "-", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"k2", "*", 
      RowBox[{"H", "[", 
       RowBox[{"a", ",", "b"}], "]"}], "*", 
      RowBox[{
       RowBox[{"dd", "[", 
        RowBox[{"-", "c"}], "]"}], "[", 
       RowBox[{
        RowBox[{"dd", "[", "c", "]"}], "[", 
        RowBox[{"H", "[", 
         RowBox[{
          RowBox[{"-", "a"}], ",", 
          RowBox[{"-", "b"}]}], "]"}], "]"}], "]"}]}], ")"}], "/", "2"}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"3", "*", "k2"}], "-", 
        RowBox[{"4", "*", "k3"}]}], ")"}], "*", 
      RowBox[{"H", "[", 
       RowBox[{"a", ",", 
        RowBox[{"-", "a"}]}], "]"}], "*", 
      RowBox[{
       RowBox[{"dd", "[", 
        RowBox[{"-", "c"}], "]"}], "[", 
       RowBox[{
        RowBox[{"dd", "[", "c", "]"}], "[", 
        RowBox[{"H", "[", 
         RowBox[{"b", ",", 
          RowBox[{"-", "b"}]}], "]"}], "]"}], "]"}]}], ")"}], "/", 
    "16"}]}]}]], "Input",
 CellChangeTimes->{{3.982992048235199*^9, 3.982992050781773*^9}, {
