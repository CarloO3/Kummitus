Cell[CellGroupData[{

Cell["\<\
Massive spin-2 - tensor-vector-scalar model (novel (?)-gauge-symmetric theory \
of spin-2 - no tuning of parameters.)\
\>", "Subsubsection",
 CellChangeTimes->{{3.98299204175062*^9, 3.982992044157013*^9}, {
   3.982994222641953*^9, 3.982994223772425*^9}, {3.982994769017606*^9, 
